# Required: Your Anthropic API key for document analysis
ANTHROPIC_API_KEY=sk-ant-your-key-here

# API authentication key (change in production)
API_KEY=dev-api-key-change-me

# Database (auto-configured in docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/govdoc
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/govdoc

# LLM model to use
LLM_MODEL=claude-sonnet-4-20250514

# Max upload file size in MB
MAX_FILE_SIZE_MB=10

# Frontend API key (used by Vite)
VITE_API_KEY=dev-api-key-change-me
